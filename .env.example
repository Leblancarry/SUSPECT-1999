# ──────────────────────────────────────────
# 复制此文件，重命名为 .env，填入你的密钥
# .env 不会被上传到 GitHub
# ──────────────────────────────────────────

# DeepSeek API
# 填写后使用 AI 角色回复；不填则使用内置固定回复（无需付费也可玩）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Flask Session 密钥（部署到公网时请改成随机字符串）
FLASK_SECRET_KEY=change-this-before-deploy
